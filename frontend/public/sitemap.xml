    -->

    <!-- Главная страница -->
    <url>
        <loc>https://nastarte.ru/</loc>
        <lastmod>2026-04-15</lastmod>
        <changefreq>daily</changefreq>
        <priority>1.0</priority>
    </url>

    <!-- Страница всех объявлений -->
    <url>
        <loc>https://nastarte.ru/competitions</loc>
